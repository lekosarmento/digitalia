.env
*.env
.env.*
.venv/
venv/
ENV/
env/

# Python Cache & Build Artifacts
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.coverage
htmlcov/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# Node.js Dependencies & Builds (Frontend React)
node_modules/
frontend/node_modules/
frontend/dist/
frontend/build/
.npm
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# IDEs, Editors & OS Files
.vscode/
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.DS_Store
Thumbs.db

# Database & Local Testing Data
pg_data/
redis_data/
localstack_data/
.localstack/
*.db
*.sqlite3
