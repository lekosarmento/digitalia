# ==========================================
# DigitalIA — Variáveis de Ambiente
# Copie este arquivo para .env e preencha os valores reais
# NUNCA commite o arquivo .env
# ==========================================
# PostgreSQL
POSTGRES_PASSWORD=troque_por_senha_segura

# JWT (gere com: python -c "import secrets; print(secrets.token_hex(32))")
JWT_SECRET_KEY=troque_por_chave_de_64_bytes_aleatorios

# LGPD / Criptografia AES-256
LGPD_ENCRYPTION_KEY=troque_por_chave_de_32_bytes_aleatorios

# WhatsApp (Meta Cloud API)
WA_APP_SECRET=troque_pelo_app_secret_do_meta
WA_VERIFY_TOKEN=troque_pelo_verify_token_do_meta
WA_ACCESS_TOKEN=troque_pelo_access_token_do_meta

# OpenAI
OPENAI_API_KEY=troque_pela_sua_chave_openai

# AWS / LocalStack (desenvolvimento local)
AWS_ACCESS_KEY_ID=test
AWS_SECRET_ACCESS_KEY=test
AWS_DEFAULT_REGION=us-east-1
